{
  "compilerOptions": {
    "target": "es2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "moduleDetection": "force",
    "typeRoots": ["./node_modules/@types"],
    "types": ["react", "react-dom"],
    "paths": {
      "@/*": ["./src/*"],
      "@cases/*": ["./src/*"]
    }
  },
  "include": ["./src"]
}
