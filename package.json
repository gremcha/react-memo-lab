{
  "name": "react-memo-research",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:18": "pnpm --filter app-react-18 dev",
    "dev:19": "pnpm --filter app-react-19 dev",
    "build": "pnpm -r build",
    "build:18": "pnpm --filter app-react-18 build",
    "build:19": "pnpm --filter app-react-19 build",
    "start": "node server.mjs",
    "lint": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react-dom": "^4.2.3",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-react-x": "^4.2.3",
    "globals": "17.4.0",
    "prettier": "^3.8.3",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "express": "4.19.2"
  }
}
